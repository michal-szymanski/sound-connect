{
    "name": "sound-connect-posts-queue-consumer",
    "main": "src/index.ts",
    "compatibility_date": "2024-11-19",
    "compatibility_flags": ["nodejs_compat"],
    "queues": {
        "consumers": [
            {
                "queue": "posts-queue",
                "max_batch_size": 10,
                "max_batch_timeout": 1,
                "max_retries": 3,
                "dead_letter_queue": "posts-queue-dlq"
            }
        ]
    },
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "sound-connect-db",
            "database_id": "ce66ac7f-5b4a-47e8-9db6-7143d996b13c"
        }
    ]
}

{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/web/*": ["src/*"],
            "@/features/*": ["src/features/*"],
            "@/shared/*": ["src/shared/*"],
            "@/common/*": ["../../packages/common/src/*"],
            "@/drizzle": ["../../packages/drizzle/src"],
            "@/drizzle/*": ["../../packages/drizzle/src/*"]
        },
        "lib": ["DOM"],
        "jsx": "react-jsx"
    },
    "include": ["src/**/*", "worker-configuration.d.ts"],
    "exclude": ["node_modules", "**/*.spec.ts"]
}

{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "sound-connect-web",
    "main": ".output/server/index.mjs",
    "compatibility_date": "2025-09-18",
    "compatibility_flags": ["nodejs_compat", "nodejs_compat_populate_process_env"],
    "assets": {
        "directory": ".output/public"
    },
    "observability": {
        "enabled": true
    },
    "vars": {
        "API_URL": "https://sound-connect-api.michal-szymanski92.workers.dev",
        "CLIENT_URL": "https://sound-connect-web.michal-szymanski92.workers.dev"
    },
    "services": [
        {
            "binding": "API",
            "service": "sound-connect-api"
        }
    ]
}

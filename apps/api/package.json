{
    "name": "@sound-connect/api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "start": "pnpm db:push && pnpm db:seed && tsx src/server.ts",
        "db:push": "drizzle-kit push",
        "db:drop": "drizzle-kit drop",
        "db:generate": "drizzle-kit generate",
        "db:migrate:remote": "wrangler d1 migrations apply sound-connect-db --remote",
        "db:migrate:local": "wrangler d1 migrations apply sound-connect-db --local",
        "db:studio": "export DB_HOST='0.0.0.0' && drizzle-kit studio",
        "db:seed": "tsx src/db/seed.ts",
        "prettier:check": "prettier . --check",
        "prettier:format": "prettier . --write",
        "ts:check": "tsc",
        "dev": "pnpm db:migrate:local && wrangler dev",
        "deploy": "wrangler deploy --minify src/server.ts",
        "types": "wrangler types --env-interface CloudflareBindings",
        "tail": "wrangler tail"
    },
    "dependencies": {
        "@sound-connect/types": "workspace:*",
        "@cloudflare/workers-types": "^4.20250312.0",
        "@types/better-sqlite3": "^7.6.12",
        "@types/cookie-parser": "^1.4.8",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/node": "^22.14.0",
        "@types/pg": "^8.11.11",
        "better-auth": "^1.2.4",
        "better-sqlite3": "^11.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "drizzle-kit": "^0.31.1",
        "drizzle-orm": "^0.43.1",
        "drizzle-seed": "^0.3.1",
        "express": "^4.21.2",
        "hono": "^4.7.4",
        "pg": "^8.13.1",
        "prettier": "^3.5.0",
        "tsx": "^4.19.2",
        "typescript": "^5.8.2",
        "wrangler": "^4.0.0",
        "zod": "^3.24.1"
    }
}

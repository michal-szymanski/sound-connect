{
    "name": "@sound-connect/api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "start": "pnpm db:push && pnpm db:seed && tsx src/server.ts",
        "db:push": "drizzle-kit push",
        "db:drop": "drizzle-kit drop",
        "db:generate": "drizzle-kit generate",
        "db:migrate:remote": "wrangler d1 migrations apply sound-connect-db --remote",
        "db:migrate:local": "wrangler d1 migrations apply sound-connect-db --local",
        "db:studio": "drizzle-kit studio",
        "db:studio:local": "drizzle-kit studio --config=drizzle-local.config.ts",
        "db:seed": "tsx src/db/seed.ts",
        "dev": "pnpm db:migrate:local && wrangler dev --local --port 4000 -c wrangler.jsonc -c ../posts-queue-consumer/wrangler.jsonc --persist-to .wrangler/state",
        "deploy": "wrangler deploy --minify src/server.ts",
        "types": "wrangler types --env-interface CloudflareBindings",
        "tail": "wrangler tail",
        "tsc": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@cloudflare/workers-types": "catalog:",
        "@sound-connect/common": "workspace:*",
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.14.0",
        "@types/pg": "^8.11.11",
        "better-auth": "catalog:",
        "better-sqlite3": "^11.8.1",
        "dotenv": "^16.4.7",
        "drizzle-kit": "^0.31.1",
        "drizzle-orm": "^0.43.1",
        "drizzle-seed": "^0.3.1",
        "hono": "catalog:",
        "pg": "^8.13.1",
        "tsx": "^4.19.2",
        "typescript": "catalog:",
        "wrangler": "catalog:",
        "zod": "catalog:"
    }
}

{
    "mcpServers": {
        "cloudflare-docs": {
            "type": "sse",
            "url": "https://docs.mcp.cloudflare.com/sse"
        },
        "cloudflare-workers-bindings": {
            "type": "sse",
            "url": "https://bindings.mcp.cloudflare.com/sse",
            "headers": {
                "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
            }
        },
        "cloudflare-workers-builds": {
            "type": "sse",
            "url": "https://builds.mcp.cloudflare.com/sse",
            "headers": {
                "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
            }
        },
        "cloudflare-observability": {
            "type": "sse",
            "url": "https://observability.mcp.cloudflare.com/sse",
            "headers": {
                "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
            }
        },
        "filesystem": {
            "type": "stdio",
            "command": "pnpm",
            "args": ["dlx", "@modelcontextprotocol/server-filesystem", "${WORKSPACE_PATH}"]
        },
        "chrome-devtools": {
            "type": "stdio",
            "command": "pnpm",
            "args": ["dlx", "chrome-devtools-mcp", "--headless=true", "--isolated=true"]
        },
        "playwright": {
            "command": "pnpm",
            "args": ["dlx", "@playwright/mcp@latest"]
        },
        "vite": {
            "type": "sse",
            "url": "http://localhost:3000/__mcp/sse"
        }
    }
}

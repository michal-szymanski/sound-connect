{
    "name": "@sound-connect/drizzle",
    "version": "1.0.0",
    "type": "module",
    "main": "./src",
    "exports": {
        ".": "./src/index.ts",
        "./schema": "./src/schema.ts"
    },
    "scripts": {
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio",
